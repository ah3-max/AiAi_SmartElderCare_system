# ==== 部署環境設定 ====

# JWT
JWT_SECRET=change-this-to-a-strong-random-string

# Line Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Line Notify
LINE_NOTIFY_TOKEN=

# LIFF build 變數（docker-compose build arg 使用）
VITE_API_URL=

# LIFF 各頁面 ID（用於 update-tunnel.sh 自動更新 LINE Developer Console）
LIFF_ID_ADMISSION=
LIFF_ID_APPOINTMENT=
LIFF_ID_VISIT=
LIFF_ID_CONTRACT=

# LIFF 應用基底 URL
LIFF_BASE_URL=https://liff.line.me/your-liff-id

# TWCA（KYC + 數位簽章）
# TWCA_SECRET 留空 → stub 模式（dev 環境自動通過，無需真實 TWCA 帳號）
TWCA_API_URL=https://api.twca.com.tw
TWCA_APP_ID=
TWCA_SECRET=
TWCA_KYC_CALLBACK_URL=https://your-domain.com/api/contracts/twca-callback

# 後端對外基底 URL（組 TWCA callback URL 用）
API_BASE_URL=https://your-domain.com/api

# 合約 PDF 儲存目錄
CONTRACT_PDF_DIR=uploads/contracts

# CJK 字型路徑（PDF 中文渲染）
# 安裝方式：apt-get install fonts-droid-fallback
CJK_FONT_PATH=/usr/share/fonts/truetype/droid/DroidSansFallbackFull.ttf
