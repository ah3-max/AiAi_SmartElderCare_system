# ==== 部署環境設定 ====

# JWT
JWT_SECRET=change-this-to-a-strong-random-string

# Line Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Line Notify
LINE_NOTIFY_TOKEN=

# LIFF build 變數（docker-compose build arg 使用）
VITE_API_URL=

# LIFF 各頁面 ID（用於 update-tunnel.sh 自動更新 LINE Developer Console）
LIFF_ID_ADMISSION=
LIFF_ID_APPOINTMENT=
LIFF_ID_VISIT=
LIFF_ID_CONTRACT=

# LIFF 應用基底 URL
LIFF_BASE_URL=https://liff.line.me/your-liff-id

# TWCA（KYC + 數位簽章）
TWCA_API_URL=https://api.twca.com.tw
TWCA_API_KEY=
