# 資料庫
DATABASE_URL="postgresql://careflow:password@localhost:5432/careflow"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="8h"

# Server
PORT=3201
ALLOWED_ORIGINS="http://localhost:3200,http://localhost:3202"

# Line Messaging API
LINE_CHANNEL_ACCESS_TOKEN="your-line-channel-access-token"
LINE_CHANNEL_SECRET="your-line-channel-secret"

# Line Notify（行政人員群組通知）
LINE_NOTIFY_TOKEN="your-line-notify-token"

# LIFF 基底 URL
LIFF_BASE_URL="https://liff.line.me/your-liff-id"

# TWCA（KYC + 數位簽章）
# TWCA_SECRET 留空 → stub 模式（dev 環境自動通過，無需真實 TWCA 帳號）
TWCA_API_URL="https://api.twca.com.tw"
TWCA_APP_ID="your-twca-app-id"
TWCA_SECRET="your-twca-secret"
TWCA_KYC_CALLBACK_URL="https://your-domain.com/contracts/twca-callback"

# 後端對外基底 URL（組 TWCA callback URL 用）
API_BASE_URL="https://your-domain.com"

# 合約 PDF 儲存目錄
CONTRACT_PDF_DIR="uploads/contracts"

# CJK 字型路徑（PDF 中文字元渲染）
# 安裝指令：apt-get install fonts-droid-fallback
CJK_FONT_PATH="/usr/share/fonts/truetype/droid/DroidSansFallbackFull.ttf"
